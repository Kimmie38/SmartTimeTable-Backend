# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://kimrwang9_db_user:keepout8888@cluster0.gvzyqhi.mongodb.net/?appName=Cluster0

# JWT
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Admin registration is locked behind this key so students can't self-register as admin.
# Whoever is creating the admin account must send this exact value in the request body.
ADMIN_REGISTRATION_KEY=adminaccessonlystudentnotallowedorgivenacess

# Used to build full URLs for uploaded attachments (e.g. http://localhost:5000)
BASE_URL=http://localhost:5000

# Firebase Cloud Messaging
# Download your Firebase service account JSON and either:
# 1) place it at ./config/firebase-service-account.json, OR
# 2) paste the full JSON (as one line) into FIREBASE_SERVICE_ACCOUNT below
FIREBASE_SERVICE_ACCOUNT=
